{
  "name": "identitree",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "test": "npm run -w apps/api test --",
    "lint": "turbo run lint",
    "check-types": "turbo run check-types"
  },
  "devDependencies": {
    "turbo": "^2.9.6",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "npm@11.8.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "dependencies": {
    "cors": "^2.8.6"
  },
  "supportedArchitectures": {
    "os": [
      "linux",
      "win32"
    ],
    "cpu": [
      "x64",
      "arm64"
    ],
    "libc": [
      "glibc",
      "musl"
    ]
  }
}
