generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                        String          @id @default(cuid())
  name                      String?
  email                     String          @unique
  image                     String?
  emailVerified             Boolean         @default(false) @map("email_verified")

  createdAt                 DateTime        @default(now()) @map("created_at")
  updatedAt                 DateTime        @updatedAt @map("updated_at")

  accounts                  Account[]
  sessions                  Session[]
  members                   Member[]
  ownedProfiles             Profile[]
  invitations               Invitation[]

  @@map("user")
}

model Account {
  id                        String          @id @default(cuid())
  accountId                 String          @map("account_id")
  providerId                String          @map("provider_id")
  accessToken               String?         @map("access_token")
  refreshToken              String?         @map("refresh_token")
  accessTokenExpiresAt      DateTime?       @map("access_token_expires_at")
  refreshTokenExpiresAt     DateTime?       @map("refresh_token_expires_at")
  scope                     String?
  idToken                   String?         @map("id_token")
  password                  String?

  userId                    String          @map("user_id")
  user                      User            @relation(fields: [userId], references: [id])

  createdAt                 DateTime        @default(now()) @map("created_at")
  updatedAt                 DateTime        @updatedAt @map("updated_at")

  @@unique([providerId, accountId])
  @@index([userId])
  @@map("account")
}

model Session {
  id                        String          @id @default(cuid())
  token                     String          @unique
  expiresAt                 DateTime        @map("expires_at")
  ipAddress                 String?         @map("ip_address")
  userAgent                 String?         @map("user_agent")
  activeOrganizationId      String?         @map("active_organization_id")

  userId                    String          @map("user_id")
  user                      User            @relation(fields: [userId], references: [id])

  createdAt                 DateTime        @default(now()) @map("created_at")
  updatedAt                 DateTime        @updatedAt @map("updated_at")

  @@index([userId])
  @@map("session")
}

model Verification {
  id                        String          @id @default(cuid())
  identifier                String
  value                     String
  expiresAt                 DateTime        @map("expires_at")

  createdAt                 DateTime        @default(now()) @map("created_at")
  updatedAt                 DateTime        @updatedAt @map("updated_at")

  @@index([identifier])
  @@map("verification")
}

// NOTE: Add owner_user_id (FK → User.id)
// - This will represent the organization owner
// - logo_url..
model Organization {
  id                        String          @id @default(cuid())
  name                      String
  slug                      String          @unique
  logo                      String?
  metadata                  String?

  createdAt                 DateTime        @default(now()) @map("created_at")
  updatedAt                 DateTime        @updatedAt @map("updated_at")

  members                   Member[]
  profiles                  Profile[]
  nfcCards                  NfcCard[]
  invitations               Invitation[]

  @@map("organization")
}

// NOTE:
// - how about adding OrganizationMemberRole enum for role?
// - also, unique constraint for userId, and organizationId?
model Member {
  id                        String          @id @default(cuid())
  role                      String
  createdAt                 DateTime        @default(now()) @map("created_at")
  updatedAt                 DateTime        @updatedAt @map("updated_at")

  userId                    String          @map("user_id")
  user                      User            @relation(fields: [userId], references: [id])

  organizationId            String          @map("organization_id")
  organization              Organization    @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
  @@index([userId])
  @@map("member")
}

model Profile {
  id                        String          @id @default(cuid())
  templateKey               String          @default("default") @map("template_key")
  firstName                 String          @map("first_name")
  lastName                  String          @map("last_name")
  email                     String
  avatarUrl                 String?         @map("avatar_url")
  positionTitle             String          @map("position_title")
  contactNumber             String          @map("contact_number")
  linkedinUsername          String?         @map("linkedin_username")
  whatsappNumber            String?         @map("whatsapp_number")
  viberNumber               String?         @map("viber_number")

  organizationId            String?         @map("organization_id")
  organization              Organization?   @relation(fields: [organizationId], references: [id])

  ownerUserId               String?         @map("owner_user_id")
  ownerUser                 User?           @relation(fields: [ownerUserId], references: [id])

  // templateId             String          @map("template_id")
  // template               Template        @relation(fields: [templateId], references: [id])

  nfcCards                   NfcCard[]

  createdAt                 DateTime        @default(now()) @map("created_at")
  updatedAt                 DateTime        @updatedAt @map("updated_at")

  @@map("profile")
}

model NfcCard {
  id                        String          @id @default(cuid())

  hardwareId                String?         @map("hardware_id")
  cardType                  NfcCardType     @map("card_type")
  encodedUrl                String          @map("encoded_url")
  status                    NfcCardStatus   @default(UNASSIGNED)

  organizationId            String?         @map("organization_id")
  organization              Organization?   @relation(fields: [organizationId], references: [id])

  profileId                 String?         @map("profile_id")
  profile                   Profile?        @relation(fields: [profileId], references: [id])

  createdAt                 DateTime        @default(now()) @map("created_at")
  updatedAt                 DateTime        @updatedAt @map("updated_at")

  @@map("nfc_card")
}

